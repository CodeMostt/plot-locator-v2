<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
    <title>Techunited - Plot Locator</title>
    <style>
        :root {
            --gold: #D4AF37; --registry: #2ecc71; --booked: #f1c40f;
            --vacant: #e74c3c; --edit: #3498db; --bg: #f4f7f6;
            --landowner: #3498db; --developer: #2c3e50;
        }

        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); margin: 0; padding: 10px; text-align: center; }

        /* Admin Bar */
        .admin-bar { text-align: right; padding: 5px 10px; font-size: 0.8rem; background: white; margin-bottom: 10px; border-radius: 8px; }
        .header h1 { color: #2c3e50; font-size: 1.4rem; margin: 10px 0; }

        /* Controls */
        .controls { display: flex; flex-direction: column; align-items: center; gap: 10px; margin-bottom: 20px; }
        .row { display: flex; justify-content: center; gap: 8px; width: 100%; max-width: 600px; flex-wrap: wrap; }
        select, input { padding: 10px; border-radius: 8px; border: 1px solid #ddd; width: 45%; outline: none; font-size: 0.9rem; }
        #plot-search { width: 60%; }
        .btn-search { background: var(--gold); color: white; border: none; padding: 10px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; }

        /* Map UI */
        .map-section { display: none; margin: 0 auto; max-width: 1200px; border: 2px solid var(--gold); border-radius: 12px; position: relative; overflow: hidden; background: white; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        #map-image { width: 100%; height: auto; display: block; z-index: 1; }
        #svg-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; pointer-events: none; }
        polygon { pointer-events: auto; cursor: pointer; transition: fill 0.2s, stroke 0.2s; }

        /* Layers Base */
        #modal-overlay { display: none; position: absolute; top: 0; left: 0; z-index: 2147483646; }
        #tooltip { position: absolute; display: none; background: white; z-index: 2147483647; text-align: left; border-top: 10px solid var(--gold); box-sizing: border-box; }

        /* Stats Styling */
        .summary-bar { display: none; justify-content: center; gap: 8px; margin-top: 15px; flex-wrap: wrap; }
        .summary-card { background: white; padding: 8px; border-radius: 8px; border-bottom: 3px solid #ddd; min-width: 90px; flex: 1; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .summary-card b { font-size: 1.1rem; color: #2c3e50; display: block; }
        .summary-card small { font-size: 0.6rem; text-transform: uppercase; color: #7f8c8d; font-weight: bold; }
        .card-reg { border-bottom-color: var(--registry); }
        .card-book { border-bottom-color: var(--booked); }
        .card-vacant { border-bottom-color: var(--vacant); }
        .card-owner { border-bottom-color: var(--landowner); }
        .card-dev { border-bottom-color: var(--developer); }

        /* PC styles */
        @media (min-width: 768px) {
            #tooltip { width: 350px; border-radius: 15px; position: fixed !important; height: auto; max-height: 85vh; padding: 0; box-shadow: 0 15px 50px rgba(0,0,0,0.3); overflow-y: auto; pointer-events: none; }
            #modal-overlay { position: fixed !important; background: rgba(0,0,0,0.4) !important; backdrop-filter: blur(2px); width: 100vw; height: 100vh; }
            #tooltip.is-centered { left: 50% !important; top: 50% !important; transform: translate(-50%, -50%) !important; pointer-events: auto !important; }
        }

        /* Mobile styles */
        @media (max-width: 767px) {
            #tooltip { width: 100vw; height: 100vh; border-radius: 0; padding: 0; overflow-y: hidden !important; }
            #modal-overlay { background: white !important; width: 100vw; height: 100vh; }
            body.no-scroll { overflow: hidden !important; touch-action: none; position: fixed; width: 100%; }
            .mobile-actions { display: flex; gap: 8px; margin-top: 5px; }
            .btn-action { flex: 1; text-decoration: none; color: white; padding: 8px; border-radius: 6px; font-size: 0.75rem; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 5px; }
            .btn-call { background: #27ae60; }
            .btn-wa { background: #25D366; }
        }

        .t-header-row { display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: white; z-index: 11; padding: 15px 20px 10px 20px; border-bottom: 1px solid #eee; margin-bottom: 10px; }
        .t-body-content { padding: 0 20px 20px 20px; }
        .t-label { font-size: 0.65rem; color: #95a5a6; text-transform: uppercase; font-weight: bold; display: block; margin-top: 10px; }
        .t-value { font-size: 1rem; color: #2c3e50; font-weight: 600; display: block; }
        .edit-input { width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; box-sizing: border-box; }
        .btn-save { background: #27ae60; color: white; border: none; padding: 14px; border-radius: 8px; font-weight: bold; width: 100%; margin-top: 15px; cursor: pointer; }
        .btn-edit-inline { margin-top:15px; width:100%; padding:12px; background:var(--edit); color:white; border:none; border-radius:8px; cursor:pointer; font-weight:bold; }
        .btn-close-right { background: #f1f1f1; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-size: 1rem; color: #333; font-weight: bold; }
    </style>
</head>
<body>
    <div id="modal-overlay" onclick="closeTooltip()"></div>
    <div class="admin-bar">
        {% if is_admin %}
            <span style="color:var(--registry); font-weight:bold;">● Admin Mode Active</span> | <a href="/logout" style="color:red; text-decoration:none;">Logout</a>
        {% else %}
            <button onclick="showLoginPrompt()" style="border:none; background:none; color:var(--gold); font-weight:bold; cursor:pointer;">Admin Login</button>
        {% endif %}
    </div>
    <div class="header"><h1>Techunited Plot Locator</h1></div>

    <div class="controls">
        <div class="row">
            <select id="city-select" onchange="updateProjects()">
                <option value="">Select City</option>
                {% for city in cities %}<option value="{{ city }}">{{ city }}</option>{% endfor %}
            </select>
            <select id="project-select" onchange="loadMap()" disabled><option>Select Project</option></select>
        </div>
        <div class="row" id="search-area" style="display:none;">
            <input type="text" id="plot-search" placeholder="Enter Plot ID">
            <button class="btn-search" onclick="searchPlot()">Find</button>
        </div>
    </div>

    <div id="map-area" class="map-section">
        <div style="position:relative; width:100%;">
            <img id="map-image" src="">
            <svg id="svg-overlay"></svg>
        </div>
    </div>

    <div class="summary-bar" id="summary-bar">
        <div class="summary-card"><b>Total</b><span id="count-total">0</span></div>
        <div class="summary-card card-reg"><small>Registry</small><b id="count-reg">0</b></div>
        <div class="summary-card card-book"><small>Booked</small><b id="count-book">0</b></div>
        <div class="summary-card card-vacant"><small>Vacant (Red)</small><b id="count-vacant">0</b></div>
        <div class="summary-card card-owner"><small>Land Owner</small><b id="count-landowner">0</b></div>
        <div class="summary-card card-dev"><small>Dev Owned</small><b id="count-developer">0</b></div>
    </div>

    <div id="tooltip"><div id="tooltip-content"></div></div>

    <script>
        const IS_ADMIN = "{{ 'true' if is_admin else 'false' }}" === "true";
        const citySel = document.getElementById('city-select'), projSel = document.getElementById('project-select');
        const mapImg = document.getElementById('map-image'), svgOverlay = document.getElementById('svg-overlay');
        const tooltip = document.getElementById('tooltip'), overlay = document.getElementById('modal-overlay');

        let isLocked = false, currentPlotData = null, activePoly = null, lastFetchedPlots = [], hideTimer;

        function highlightPolygon(poly, status, manualColor) {
            if (activePoly && activePoly !== poly) resetPolygon(activePoly);
            activePoly = poly;
            const colors = getColor(status, manualColor);
            poly.setAttribute("fill", colors.fill.replace("0.4", "0.7").replace("0.2", "0.7"));
            poly.setAttribute("stroke", colors.color);
            poly.setAttribute("stroke-width", "4");
        }

        function resetPolygon(poly) {
            if (poly) {
                const id = poly.id.replace('poly-', '');
                const plot = lastFetchedPlots.find(p => String(p.plot_id).trim() === id);
                if (plot) {
                    const colors = getColor(plot.status, plot.color);
                    poly.setAttribute("fill", colors.fill);
                    poly.setAttribute("stroke", colors.color);
                    poly.setAttribute("stroke-width", "1");
                }
            }
        }

        function applyZoomProofLayout() {
            if (window.innerWidth < 768 && tooltip.style.display === 'block') {
                const vv = window.visualViewport;
                tooltip.style.top = vv.offsetTop + 'px';
                tooltip.style.left = vv.offsetLeft + 'px';
                tooltip.style.width = vv.width + 'px';
                tooltip.style.height = vv.height + 'px';
                overlay.style.top = vv.offsetTop + 'px';
                overlay.style.left = vv.offsetLeft + 'px';
                overlay.style.width = vv.width + 'px';
                overlay.style.height = vv.height + 'px';
                overlay.style.display = 'block';
                document.body.classList.add('no-scroll');

                const scale = 1 / vv.scale;
                const inner = document.getElementById('tooltip-content');
                inner.style.transform = `scale(${scale})`;
                inner.style.transformOrigin = 'top left';
                inner.style.width = (100 * vv.scale) + '%';
            }
        }

        if (window.visualViewport) {
            window.visualViewport.addEventListener('scroll', applyZoomProofLayout);
            window.visualViewport.addEventListener('resize', applyZoomProofLayout);
        }

        function updateProjects() {
            fetch(`/get_projects?city=${citySel.value}`).then(res => res.json()).then(projects => {
                projSel.innerHTML = '<option value="">Select Project</option>';
                projects.forEach(p => {
                    let opt = document.createElement('option');
                    opt.value = p; opt.innerHTML = p.replace(/_/g, ' ').toUpperCase();
                    projSel.appendChild(opt);
                });
                projSel.disabled = false;
            });
        }

        function loadMap() {
            mapImg.src = `/static/${citySel.value}/${projSel.value}/map.png`;
            document.getElementById('map-area').style.display = 'block';
            fetch(`/get_all_plots?city=${citySel.value}&project=${projSel.value}`).then(res => res.json()).then(plots => {
                lastFetchedPlots = plots;
                document.getElementById('search-area').style.display = 'flex';
                updateSummary(plots);
                mapImg.onload = () => renderPlots(plots);
                if(mapImg.complete) mapImg.onload();
            });
        }

        function getColor(status, manualColor) {
            if (manualColor === 'blue') return { color: "#3498db", fill: "rgba(52, 152, 219, 0.4)" };
            if (manualColor === 'orange') return { color: "#e67e22", fill: "rgba(230, 126, 34, 0.4)" };
            const s = status.trim().toLowerCase();
            if (s.includes('reg')) return { color: "#2ecc71", fill: "rgba(46, 204, 113, 0.4)" };
            if (s.includes('book')) return { color: "#f1c40f", fill: "rgba(241, 196, 15, 0.4)" };
            return { color: "#e74c3c", fill: "rgba(231, 76, 60, 0.2)" };
        }

        function renderPlots(plots) {
            svgOverlay.innerHTML = '';
            svgOverlay.setAttribute('viewBox', `0 0 ${mapImg.naturalWidth} ${mapImg.naturalHeight}`);
            plots.forEach(plot => {
                const poly = document.createElementNS("http://www.w3.org/2000/svg", "polygon");
                poly.setAttribute("points", plot.coords);
                const colors = getColor(plot.status, plot.color);
                poly.setAttribute("fill", colors.fill);
                poly.setAttribute("stroke", colors.color);
                poly.setAttribute("stroke-width", "1");
                poly.id = "poly-" + String(plot.plot_id).trim();

                poly.onmouseenter = (e) => {
                    if (!isLocked && window.innerWidth >= 768) {
                        clearTimeout(hideTimer);
                        highlightPolygon(poly, plot.status, plot.color);
                        showInfo(plot, e.clientX, e.clientY);
                    }
                };
                poly.onmouseleave = () => {
                    if (!isLocked && window.innerWidth >= 768) {
                        hideTimer = setTimeout(() => { if (!tooltip.matches(':hover')) closeTooltip(); }, 150);
                    }
                };
                poly.onclick = (e) => {
                    isLocked = true;
                    highlightPolygon(poly, plot.status, plot.color);
                    showInfo(plot, e.clientX, e.clientY);
                };
                if (IS_ADMIN) poly.oncontextmenu = (e) => {
                    e.preventDefault();
                    isLocked = true;
                    highlightPolygon(poly, plot.status, plot.color);
                    startEdit(plot);
                };
                svgOverlay.appendChild(poly);
            });
        }

        function showInfo(data, x, y) {
            currentPlotData = data;
            const colors = getColor(data.status, data.color);
            const isBlue = data.color === 'blue';
            const plotType = isBlue ? "Land Owner" : "Developer Owned";

            let content = `
                <div class="t-header-row">
                    <span class="t-value" style="color:var(--gold); font-size:1.4rem;">Plot #${data.plot_id}</span>
                    <button class="btn-close-right" onclick="closeTooltip()">DONE</button>
                </div>
                <div class="t-body-content">
                    <span class="t-label">Type</span><span class="t-value" style="color:${isBlue ? 'var(--landowner)' : 'var(--developer)'}">${plotType}</span>
                    <span class="t-label">Size</span><span class="t-value">${data.size || 'N/A'}</span>`;

            // CRITICAL FIX: Hide Status row if plot is Blue (Land Owner)
            if (!isBlue) {
                content += `<span class="t-label">Status</span><span class="t-value" style="color:${colors.color}">${data.status}</span>`;
            }

            content += `<span class="t-label">Owner</span><span class="t-value">${data.owner || 'N/A'}</span>`;

            if (!data.status.toLowerCase().includes('vac')) {
                let phone = data.customer_number || 'N/A';
                content += `<span class="t-label">Number</span><span class="t-value">${phone}</span>`;
                if(phone !== 'N/A') {
                    content += `
                    <div class="mobile-actions">
                        <a href="tel:${phone}" class="btn-action btn-call">Call</a>
                        <a href="https://wa.me/${phone}?text=Hello, I am inquiring about Plot No: ${data.plot_id}" target="_blank" class="btn-action btn-wa">WhatsApp</a>
                    </div>`;
                }
                content += `<span class="t-label">Booking Date</span><span class="t-value">${data.booking_date || 'N/A'}</span>`;
            }
            if (data.status.toLowerCase().includes('reg')) {
                content += `<span class="t-label">Registry Date</span><span class="t-value">${data.registry_date || 'N/A'}</span>`;
            }
            if (IS_ADMIN) content += `<button class="btn-edit-inline" onclick="startEdit(currentPlotData)">Edit Details</button>`;

            document.getElementById('tooltip-content').innerHTML = content + '</div>';
            tooltip.style.display = 'block';

            if (window.innerWidth >= 768) {
                if (isLocked) {
                    tooltip.classList.add('is-centered');
                    overlay.style.display = 'block';
                } else {
                    tooltip.classList.remove('is-centered');
                    tooltip.style.left = (x + 25) + 'px';
                    tooltip.style.top = (y + 25) + 'px';
                    overlay.style.display = 'none';
                }
            } else {
                applyZoomProofLayout();
            }
        }

        function startEdit(data) {
            isLocked = true; currentPlotData = data;
            document.getElementById('tooltip-content').innerHTML = `
                <div class="t-header-row">
                    <strong style="color:var(--edit); font-size:1.2rem;">Edit #${data.plot_id}</strong>
                    <button class="btn-close-right" onclick="closeTooltip()">CANCEL</button>
                </div>
                <div class="t-body-content">
                    <span class="t-label">Size</span><input type="text" id="edit-size" value="${data.size || ''}" class="edit-input">
                    <span class="t-label">Status</span>
                    <select id="edit-status" class="edit-input">
                        <option value="Registry done" ${data.status.includes('Reg') ? 'selected' : ''}>Registry done</option>
                        <option value="Booked" ${data.status.includes('Book') ? 'selected' : ''}>Booked</option>
                        <option value="Vacant" ${data.status.includes('Vac') ? 'selected' : ''}>Vacant</option>
                    </select>
                    <span class="t-label">Plot Colour (Manual)</span>
                    <select id="edit-color" class="edit-input">
                        <option value="" ${!data.color ? 'selected' : ''}>Default</option>
                        <option value="blue" ${data.color === 'blue' ? 'selected' : ''}>Blue (Land Owner)</option>
                        <option value="orange" ${data.color === 'orange' ? 'selected' : ''}>Orange</option>
                    </select>
                    <span class="t-label">Owner</span><input type="text" id="edit-owner" value="${data.owner === 'undefined' || !data.owner ? '' : data.owner}" class="edit-input">
                    <span class="t-label">Number</span><input type="text" id="edit-num" value="${data.customer_number === 'undefined' || !data.customer_number ? '' : data.customer_number}" class="edit-input">
                    <span class="t-label">Booking Date</span><input type="date" id="edit-book-date" value="${data.booking_date || ''}" class="edit-input">
                    <span class="t-label">Registry Date</span><input type="date" id="edit-reg-date" value="${data.registry_date || ''}" class="edit-input">
                    <button class="btn-save" onclick="saveDetails()">Save Changes</button>
                </div>`;
            tooltip.style.display = 'block';
            if (window.innerWidth >= 768) { tooltip.classList.add('is-centered'); overlay.style.display = 'block'; }
            else { applyZoomProofLayout(); }
        }

        function saveDetails() {
            const body = { city: citySel.value, project: projSel.value, plot_id: currentPlotData.plot_id, size: document.getElementById('edit-size').value, status: document.getElementById('edit-status').value, color: document.getElementById('edit-color').value, owner: document.getElementById('edit-owner').value, customer_number: document.getElementById('edit-num').value, booking_date: document.getElementById('edit-book-date').value, registry_date: document.getElementById('edit-reg-date').value };
            fetch('/save_plot_details', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
            .then(res => res.json()).then(res => { if(res.success) { closeTooltip(); loadMap(); } });
        }

        function closeTooltip() {
            isLocked = false;
            if (activePoly) resetPolygon(activePoly);
            tooltip.style.display = 'none';
            overlay.style.display = 'none';
            tooltip.classList.remove('is-centered');
            document.body.classList.remove('no-scroll');
            document.getElementById('tooltip-content').style.transform = 'none';
        }

        document.addEventListener('mousemove', (e) => {
            if (!isLocked && window.innerWidth >= 768 && tooltip.style.display === 'block') {
                tooltip.style.left = (e.clientX + 25) + 'px';
                tooltip.style.top = (e.clientY + 25) + 'px';
                tooltip.style.transform = 'none';
            }
        });

        function showLoginPrompt() {
            const user = prompt("User:"), pass = prompt("Pass:");
            if (user && pass) {
                fetch('/login', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({username: user, password: pass}) })
                .then(res => res.json()).then(data => { if(data.success) location.reload(); else alert("Denied"); });
            }
        }

        function updateSummary(plots) {
            const total = plots.length;
            const reg = plots.filter(p => p.status.toLowerCase().includes('reg')).length;
            const book = plots.filter(p => p.status.toLowerCase().includes('book')).length;
            const vacant = plots.filter(p => p.status.toLowerCase().includes('vacant') && p.color !== 'blue').length;
            const landowner = plots.filter(p => p.color === 'blue').length;
            const developer = total - landowner;

            document.getElementById('count-total').innerText = total;
            document.getElementById('count-reg').innerText = reg;
            document.getElementById('count-book').innerText = book;
            document.getElementById('count-vacant').innerText = vacant;
            document.getElementById('count-landowner').innerText = landowner;
            document.getElementById('count-developer').innerText = developer;
            document.getElementById('summary-bar').style.display = 'flex';
        }

        function searchPlot() {
            const searchId = document.getElementById('plot-search').value.trim();
            const match = lastFetchedPlots.find(p => String(p.plot_id).trim() === searchId);
            if (match) {
                isLocked = true;
                const poly = document.getElementById("poly-" + searchId);
                if (poly) highlightPolygon(poly, match.status, match.color);
                showInfo(match, window.innerWidth/2, window.innerHeight/2);
                poly?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else alert("ID not found");
        }
    </script>
</body>
</html>


from flask import Flask, render_template, jsonify, request, session, redirect, url_for
import csv
import os

app = Flask(__name__)
# Secure key for session management
app.secret_key = "techunited_plot_locator_secure_2026"

# --- CONFIGURATION ---
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "password123"

CITIES_CONFIG = {
    "Khandwa": ["muffadal_park", "smart_city"],
    "Mundi": ["mahaveer_nagar", "royal_residency"]
}

# Use absolute paths to ensure the 'data' folder is always found
BASE_DIR = os.path.dirname(os.path.abspath(__file__))

def get_csv_path(city, project):
    return os.path.join(BASE_DIR, 'data', city, f"{project}.csv")

# --- ROUTES ---

@app.route('/')
def index():
    is_admin = session.get('is_admin', False)
    return render_template('index.html', cities=CITIES_CONFIG.keys(), is_admin=is_admin)

@app.route('/login', methods=['POST'])
def login():
    data = request.json
    if data.get('username') == ADMIN_USERNAME and data.get('password') == ADMIN_PASSWORD:
        session['is_admin'] = True
        return jsonify({"success": True})
    return jsonify({"success": False})

@app.route('/logout')
def logout():
    session.clear() # Clears admin status completely
    return redirect(url_for('index'))

@app.route('/get_projects')
def get_projects():
    city = request.args.get('city')
    return jsonify(CITIES_CONFIG.get(city, []))

@app.route('/get_all_plots')
def get_all_plots():
    city = request.args.get('city')
    project = request.args.get('project')
    csv_path = get_csv_path(city, project)
    
    plots = []
    if os.path.exists(csv_path):
        try:
            with open(csv_path, mode='r', encoding='utf-8') as file:
                reader = csv.DictReader(file)
                for row in reader:
                    # Clean data and remove quotes from coordinates
                    clean_row = {str(k).strip(): str(v).strip() for k, v in row.items() if k and v}
                    if 'coords' in clean_row:
                        clean_row['coords'] = clean_row['coords'].replace('"', '')
                    plots.append(clean_row)
            return jsonify(plots)
        except Exception as e:
            return jsonify({"error": str(e)}), 500
    return jsonify({"error": "CSV not found"}), 404

@app.route('/save_plot_details', methods=['POST'])
def save_plot_details():
    if not session.get('is_admin'):
        return jsonify({"error": "Unauthorized"}), 403

    data = request.json
    csv_path = get_csv_path(data['city'], data['project'])
    updated_rows = []
    
    try:
        # Read and Update
        with open(csv_path, mode='r', encoding='utf-8') as file:
            reader = csv.DictReader(file)
            fieldnames = reader.fieldnames
            for row in reader:
                if str(row['plot_id']).strip() == str(data['plot_id']).strip():
                    row.update({
                        'status': data['status'],
                        'owner': data['owner'],
                        'size': data['size'],
                        'customer_number': data['customer_number'],
                        'booking_date': data['booking_date'],
                        'registry_date': data['registry_date']
                    })
                updated_rows.append(row)

        # Write changes back to CSV
        with open(csv_path, mode='w', encoding='utf-8', newline='') as file:
            writer = csv.DictWriter(file, fieldnames=fieldnames)
            writer.writeheader()
            writer.writerows(updated_rows)
        return jsonify({"success": True})
    except Exception as e:
        return jsonify({"error": str(e)}), 500

if __name__ == '__main__':
    app.run(debug=True, port=5000).env
